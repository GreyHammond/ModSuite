# ── Required ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=

# ── Dashboard OAuth2 (optional -- needed for authenticated dashboard access) ─
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
# e.g. http://localhost:8000/auth/callback or https://yourdomain.com/auth/callback
MODSUITE_GUILD_ID=
# The guild ID to restrict dashboard access to
DASHBOARD_ALLOWED_ROLES=
# Comma-separated role IDs that can access the dashboard

# ── API server (optional -- defaults shown) ───────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── CORS origins (optional) ──────────────────────────────────────────────────
# Localhost origins are always allowed. Add your server's public IP or domain
# here as a comma-separated list if accessing the dashboard remotely.
# e.g. http://myserver.com,http://10.0.0.5:8000
CORS_ORIGINS=

# ── Twitch (optional -- only needed if using /streamer alerts) ────────────────
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
